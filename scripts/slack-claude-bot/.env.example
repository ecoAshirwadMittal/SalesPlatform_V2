# Slack app credentials — get from https://api.slack.com/apps
# NEVER commit the real .env file. It is gitignored.
SLACK_APP_TOKEN=xapp-xxxx        # Socket Mode app-level token (xapp-)
SLACK_BOT_TOKEN=xoxb-xxxx        # Bot OAuth token (xoxb-)

# Absolute path to the repo Claude should work in
REPO_PATH=C:\Users\Ashirwad.Mittal\mendix-extractor\SalesPlatform_Modern

# Path to the claude CLI (adjust if not on PATH)
CLAUDE_BIN=claude

# Permission mode: plan | acceptEdits | bypassPermissions
# Start with "plan" — safest. Switch to acceptEdits once you trust it.
CLAUDE_PERMISSION_MODE=plan

# Comma-separated Slack user IDs allowed to trigger the bot (U01234...)
# Leave empty to allow anyone in channels the bot is in (NOT recommended).
ALLOWED_USER_IDS=
