<p local-id=3D"397d6c31746e"><a class=3D"external-link" data-card-appearanc=
e=3D"inline" href=3D"https://docs.aws.amazon.com/secretsmanager/latest/user=
guide/best-practices.html" local-id=3D"60c072db2998" rel=3D"nofollow">https=
://docs.aws.amazon.com/secretsmanager/latest/userguide/best-practices.html<=
/a></p></td>
</tr>
<tr data-local-id=3D"3c4d01b7-c4e6-4ea1-a51c-a92e669008df">
