</tr>
<tr data-local-id=3D"baf86d40-fb9c-4f55-a719-1fb98e47a053">
<td data-local-id=3D"a8cc0d83-491d-44f4-8012-3ff402909be9" class=3D"conflue=
nceTd">
<p local-id=3D"79921b484f3e"><code>correlationId</code></p></td>
<td data-local-id=3D"770aca8c-2b4c-4ab2-a6eb-f27a91594283" class=3D"conflue=
nceTd">
<p local-id=3D"5a0b10446482">string</p></td>
<td data-local-id=3D"a0325903-8a8b-427c-9e37-897d673cbaf1" class=3D"conflue=
nceTd">
<p local-id=3D"cf52118ec0b2">Yes =E2=80=94 set by producer</p></td>
<td data-local-id=3D"8eebb7e6-a9e4-4e59-ab02-c8e269bb0282" class=3D"conflue=
nceTd">
<p local-id=3D"001092acb285"><code>"session-abc-123"</code></p></td>
<td data-local-id=3D"583e4297-5be9-4a2d-91c4-22cbf2785b35" class=3D"conflue=
nceTd">
<p local-id=3D"222980d322a7">Trace ID linking related events across systems=
. Format: <code>{topic}-{newguid}</code></p></td>
</tr>
<tr data-local-id=3D"4ca2225d-a206-4b35-b7b5-abec1c3f179e">
<td data-local-id=3D"12f60b7c-2cef-4b96-b676-e3a02aef09e2" class=3D"conflue=
nceTd">
<p local-id=3D"5a4d2959ea0e"><code>schemaVersion</code></p></td>
